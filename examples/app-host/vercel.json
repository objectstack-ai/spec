{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "bash scripts/build-vercel.sh",
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "node_modules/better-sqlite3/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/[[...route]]" }
  ]
}
