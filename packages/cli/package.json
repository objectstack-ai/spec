{
  "name": "@objectstack/cli",
  "version": "4.0.4",
  "description": "Command Line Interface for ObjectStack Protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "objectstack": "./bin/run.js",
    "os": "./bin/run.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "lint": "eslint src"
  },
  "keywords": [
    "objectstack",
    "cli",
    "oclif",
    "compiler",
    "scaffold"
  ],
  "type": "module",
  "author": "Steedos",
  "license": "Apache-2.0",
  "oclif": {
    "bin": "os",
    "dirname": "objectstack",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands",
      "glob": "**/*.js"
    },
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " "
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.105",
    "@objectstack/client": "workspace:*",
    "@objectstack/core": "workspace:*",
    "@objectstack/driver-memory": "workspace:^",
    "@objectstack/objectql": "workspace:^",
    "@objectstack/plugin-audit": "workspace:*",
    "@objectstack/plugin-auth": "workspace:*",
    "@objectstack/plugin-hono-server": "workspace:*",
    "@objectstack/plugin-security": "workspace:*",
    "@objectstack/rest": "workspace:*",
    "@objectstack/runtime": "workspace:^",
    "@objectstack/service-ai": "workspace:*",
    "@objectstack/service-cloud": "workspace:*",
    "@objectstack/spec": "workspace:*",
    "@oclif/core": "^4.10.6",
    "bundle-require": "^5.1.0",
    "chalk": "^5.6.2",
    "dotenv-flow": "^4.1.0",
    "tsx": "^4.21.0",
    "yaml": "^2.4.1",
    "zod": "^4.4.1"
  },
  "peerDependencies": {
    "@objectstack/core": "workspace:^"
  },
  "devDependencies": {
    "@oclif/plugin-help": "^6.2.46",
    "@oclif/plugin-plugins": "^5.4.63",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/objectstack-ai/framework.git",
    "directory": "packages/cli"
  },
  "homepage": "https://objectstack.ai/docs",
  "bugs": "https://github.com/objectstack-ai/framework/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
