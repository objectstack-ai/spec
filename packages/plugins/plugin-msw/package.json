    "@objectstack/types": "workspace:*",
    "msw": "^2.13.2"
  },
  "devDependencies": {
    "@objectstack/runtime": "workspace:*",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
