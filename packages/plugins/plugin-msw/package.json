{
  "name": "@objectstack/plugin-msw",
  "version": "4.0.4",
  "description": "MSW (Mock Service Worker) Plugin for ObjectStack Runtime",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
