    "@objectstack/spec": "workspace:*",
    "better-auth": "^1.5.5"
  },
  "devDependencies": {
    "@objectstack/cli": "workspace:*",
    "@types/node": "^25.5.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
