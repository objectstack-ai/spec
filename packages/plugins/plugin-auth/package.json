    "info": "objectstack info"
  },
  "dependencies": {
    "@objectstack/core": "workspace:*",
    "@objectstack/spec": "workspace:*",
    "better-auth": "^1.6.2"
  },
  "devDependencies": {
    "@objectstack/cli": "workspace:*",
    "@types/node": "^25.6.0",
