    "vitest": "^4.1.4"
  },
  "keywords": [
    "objectstack",
    "plugin",
    "auth",
    "authentication",
    "better-auth"
  ],
  "author": "ObjectStack",
  "repository": {
    "type": "git",
    "url": "https://github.com/objectstack-ai/framework.git",
    "directory": "packages/plugins/plugin-auth"
  },
  "homepage": "https://objectstack.ai/docs",
  "bugs": "https://github.com/objectstack-ai/framework/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
