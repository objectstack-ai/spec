{
  "name": "@objectstack/plugin-auth",
  "version": "4.0.4",
  "license": "Apache-2.0",
  "description": "Authentication & Identity Plugin for ObjectStack",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
